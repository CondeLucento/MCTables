\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{MCTables}

\RequirePackage{xparse}
\RequirePackage{xcolor}
\RequirePackage{expl3}

\ExplSyntaxOn

\newcounter{fifoHits}
\newcounter{fifoFaults}

\seq_new:N \l_lucent_frames_seq
\seq_new:N \l_lucent_seq_seq

\int_new:N \l_lucent_row_int

%%%%%%%%%%% COMANDO MCT %%%%%%%%%%%%%%%%%
\newcommand{\MCT}{%
  {\LARGE MCT}{\small ables}%
}

%%%%%%%%%%% FALLO %%%%%%%%%%%%%%%%%
\NewDocumentCommand{\fallo}{m}
{
\stepcounter{fifoFaults}
\fcolorbox{red}{white}{#1}
}

%%%%%%%%%%% ACIERTO%%%%%%%%%%%%%%%%%
\NewDocumentCommand{\acierto}{m}
{
\stepcounter{fifoHits}
{\color{green!60!black}#1}
}

%%%%%%%%%%% FLU %%%%%%%%%%%%%%%%%
\NewDocumentCommand{\flu}{m}
{
  \raisebox{-0.5ex}{\scriptsize\textcolor{blue}{#1}}
}

%%%%%%%%%%% FIFO %%%%%%%%%%%%%%%%%
\NewDocumentCommand{\fifo}{m m o O{FIFO}}
{
    \setcounter{fifoHits}{0}
    \setcounter{fifoFaults}{0}

    % Guardamos marcos y secuencia
    \seq_set_split:Nnn \l_lucent_frames_seq { , } { #1 }
    \seq_set_split:Nnn \l_lucent_seq_seq { , } { #2 }

    \int_gset:Nn \l_lucent_row_int { 1 } 

    \IfValueT{#3}{
        % Título visible
        \section*{#3}
        % Añadimos al índice con prefijo opcional (por defecto "FIFO")
        \addcontentsline{toc}{section}{\textsc{#4}:~#3}
    }

    \begin{center}
    \renewcommand{\arraystretch}{1.2}
    \setlength{\tabcolsep}{4pt}

    \int_set:Nn \l_tmpa_int { \seq_count:N \l_lucent_seq_seq }

    \begin{tabular}{c|*{\int_use:N \l_tmpa_int}{c}}
    & \seq_use:Nn \l_lucent_seq_seq { & } \\
    \hline
}

%%%%%%%%%%% FILA %%%%%%%%%%%%%%%%%
\NewDocumentCommand{\fila}{m}
{
    \seq_item:Nn \l_lucent_frames_seq { \int_use:N \l_lucent_row_int }
    & 
    #1 
    \int_gincr:N \l_lucent_row_int 
    \\ 
}

%%%%%%%%%%% FIN FIFO %%%%%%%%%%%%%%%%%
\NewDocumentCommand{\endfifo}{}{
\end{tabular}

\vspace{1em}

\begin{center}
\begin{flushleft}
\large\textbf{Aciertos}: \arabic{fifoHits} \par

\large\textbf{Fallos}: \arabic{fifoFaults} \par \vspace{2.5mm}

\large\textbf{TA}: \arabic{fifoHits}/\the\numexpr\value{fifoHits}+\value{fifoFaults}\relax
\par
\large\textbf{TF}: \arabic{fifoFaults}/\the\numexpr\value{fifoHits}+\value{fifoFaults}\relax
\end{flushleft}

\end{center}

\par\noindent\rule{\linewidth}{0.4pt}

\end{center}
}

\ExplSyntaxOff